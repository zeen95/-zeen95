    <script type="text/javascript">


        function load() {
            //Sys.WebForms.PageRequestManager.getInstance().add_endRequest(EndRequestHandler);
        }

        function EndRequestHandler() {

            //========confirmation

            $(function ($) {
                $('.ask').jConfirmAction();
            });

            ///==========watermark
            $(function () {
                $('.watermarked').watermark('watermark');

            });

            //========datetpicker
            $(function () {

                $("input[id$=Date]").datepicker({
                    changeMonth: true,
                    changeYear: true,
                    showOn: 'both',
                    buttonImage: '/resources/images/calendar.gif',
                    buttonImageOnly: false,
                    gotoCurrent: true,
                    dateFormat: 'dd/mm/yy',
                    closeText: 'Done'
                });
            });

        }
    </script>

    <style type="text/css">
        #progressBackgroundFilter {
            position: fixed;
            top: 0px;
            bottom: 0px;
            left: 0px;
            right: 0px;
            overflow: hidden;
            padding: 0;
            margin: 0;
            background-color: #000;
            filter: alpha(opacity=50);
            opacity: 0.5;
            z-index: 1000;
            height: 100%;
        }

        #processMessage {
            position: fixed;
            top: 200px;
            left: 43%;
            padding: 10px;
            width: 14%;
            z-index: 1001;
            background-color: #fff;
            text-align: center;
        }

        .ddlClass {
            font-size: 18px;
            height: 30px;
            line-height: 30px;
            width: 100px; /*scrollbar-face-color: #FFCCCC;
        scrollbar-highlight-color: #4B4B4B;
        scrollbar-3dlight-color: #646464;
        scrollbar-darkshadow-color: #969696;
        scrollbar-shadow-color: #C0C0C0;
        scrollbar-arrow-color: #090925;
        scrollbar-track-color: #051011;*/
        }

        .pgr {
            background: #424242 url(grd_pgr.png) repeat-x top;
        }

            .pgr table {
                margin: 5px 0;
            }

            .pgr td {
                border-width: 0;
                padding: 0 6px;
                border-left: solid 1px #666;
                font-weight: bold;
                color: #fff;
                line-height: 12px;
            }

            .pgr a {
                color: #666;
                text-decoration: none;
            }

                .pgr a:hover {
                    color: #000;
                    text-decoration: none;
                }
    </style>
